# ─────────────────────────────────────────────
#  WhatsApp MCP Frontend — Environment Variables
# ─────────────────────────────────────────────

# Point to your deployed backend (empty = same origin, Vite proxy handles it in dev)
VITE_API_BASE_URL=https://your-backend.onrender.com

# Same API key as the backend
VITE_API_KEY=your_super_secret_api_key_here_change_this
